---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 — Página não encontrada · Daniel Paiva"
  description="Esta página não existe. Volte para o currículo de Daniel Paiva."
>
  <main class="not-found">
    <!-- Grid background -->
    <div class="grid-bg" aria-hidden="true"></div>

    <!-- Orb -->
    <div class="orb" aria-hidden="true"></div>

    <div class="content">
      <p class="error-code" aria-hidden="true">404</p>

      <h1 class="title">Página não encontrada</h1>

      <p class="description">
        Parece que essa rota não existe.<br/>
        Mas o currículo está logo ali.
      </p>

      <a href="/" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M7 3L2 8L7 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M2 8H14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
        Voltar ao início
      </a>

      <p class="logo-hint" aria-hidden="true">
        <span class="bracket">&lt;</span>dp<span class="bracket">/&gt;</span>
      </p>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--bg-base);
  }

  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(88,166,255,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88,166,255,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 100%);
  }

  .orb {
    position: absolute;
    width: 600px; height: 600px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(88,166,255,0.07) 0%, transparent 70%);
    filter: blur(60px);
    pointer-events: none;
  }

  .content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
    padding: 2rem;
  }

  .error-code {
    font-family: var(--font-mono);
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: 900;
    line-height: 1;
    background: linear-gradient(135deg, rgba(88,166,255,0.15), rgba(188,140,255,0.15));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: -0.05em;
    margin-bottom: -0.5rem;
    user-select: none;
  }

  .title {
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 800;
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .description {
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 360px;
  }

  .logo-hint {
    margin-top: 2rem;
    font-family: var(--font-mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-muted);
  }

  .bracket { color: var(--blue); opacity: 0.4; }
</style>
