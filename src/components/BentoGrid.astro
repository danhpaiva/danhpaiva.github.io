---
import { Image } from 'astro:assets';
import photo from '../assets/photo.jpg';
import { stats, location, aboutLinks } from '../data/about';
import { jobs } from '../data/experience';
import { skillGroups, techBadges } from '../data/skills';
import { education } from '../data/education';
import { contactLinks } from '../data/contact';
---

<div class="bento">

  <!-- ── Name ────────────────────────────────── -->
  <article class="cell cell-name animate-fade-up" id="inicio" transition:name="cell-name">
    <p class="eyebrow">Software Engineer</p>
    <h1 class="big-name">Daniel<br>Paiva</h1>
    <p class="mono-title">
      <span id="typing-text"></span><span class="cursor" aria-hidden="true">_</span>
    </p>
    <p class="name-desc">
      Sistemas distribuídos · <strong>.NET 10</strong> · AWS · Microserviços
    </p>
    <div class="name-actions">
      <a href="#experiencia" class="btn btn-primary">Ver Experiência →</a>
      <a href="https://www.linkedin.com/in/danhpaiva/" target="_blank" rel="noopener noreferrer" class="btn btn-outline">LinkedIn</a>
      <a href="https://github.com/danhpaiva" target="_blank" rel="noopener noreferrer" class="btn btn-outline">GitHub</a>
    </div>
  </article>

  <!-- ── Photo ───────────────────────────────── -->
  <article class="cell cell-photo animate-fade-up" style="animation-delay:.08s" transition:name="cell-photo">
    <div class="photo-frame" id="photo-frame">
      <Image src={photo} alt="Daniel Paiva" width={160} height={160}
             format="webp" quality={85}
             onerror="this.parentElement.classList.add('no-photo')" />
      <div class="photo-fallback">DP</div>
    </div>
    <p class="photo-name">Daniel Paiva</p>
    <p class="photo-role">Engenheiro de Software</p>
    <div class="avail-row">
      <span class="avail-dot" aria-hidden="true"></span>
      <span>Disponível</span>
    </div>
  </article>

  <!-- ── Bio ─────────────────────────────────── -->
  <article class="cell cell-bio animate-fade-up" id="sobre" style="animation-delay:.12s">
    <p class="eyebrow">Sobre</p>
    <p class="bio-text">
      Especialista em <strong>.NET</strong> e <strong>Arquitetura de Sistemas Distribuídos</strong>.
      Atualmente na Base2 Tecnologia liderando APIs de alta performance integradas à AWS.
      Em paralelo, professor universitário de Engenharia de Software.
    </p>
    <div class="about-links">
      {aboutLinks.map((link) => (
        <a href={link.href}
           target={link.href.startsWith('http') ? '_blank' : undefined}
           rel="noopener noreferrer"
           class="about-link">
          <Fragment set:html={link.icon} />
          {link.label}
        </a>
      ))}
    </div>
  </article>

  <!-- ── Stats ───────────────────────────────── -->
  <article class="cell cell-stats animate-fade-up" style="animation-delay:.16s">
    {stats.map((stat) => (
      <div class="stat">
        <span class="stat-val" data-start-year={stat.startYear ?? null}>{stat.value}</span>
        <span class="stat-lbl">{stat.label}</span>
      </div>
    ))}
  </article>

  <!-- ── Location ────────────────────────────── -->
  <article class="cell cell-location animate-fade-up" style="animation-delay:.2s">
    <div class="loc-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <div>
        <strong>{location.city}</strong>
        <span>{location.region}</span>
      </div>
    </div>
    <div class="loc-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="2" y="3" width="20" height="14" rx="2"/>
        <path d="M8 21h8M12 17v4"/>
      </svg>
      <div>
        <strong>{location.workMode}</strong>
        <span>{location.workModeDetail}</span>
      </div>
    </div>
  </article>

  <!-- ── Stack ───────────────────────────────── -->
  <article class="cell cell-stack animate-fade-up" style="animation-delay:.24s">
    <p class="eyebrow">Stack Técnica</p>
    <div class="badges-wrap">
      {techBadges.map((badge) => <span class="tag">{badge}</span>)}
    </div>
  </article>

  <!-- ── Experience ──────────────────────────── -->
  <article class="cell cell-experience reveal" id="experiencia">
    <p class="eyebrow">Experiência</p>
    <div class="exp-list">
      {jobs.map((job, i) => (
        <div class={`exp-item${i < jobs.length - 1 ? ' sep' : ''}`}>
          <div class="exp-row-top">
            <div class="exp-left">
              <p class="exp-co">{job.company}</p>
              <p class="exp-role-name">
                {job.role}
                {job.subtitle && <span class="exp-sub"> · {job.subtitle}</span>}
              </p>
            </div>
            <div class="exp-right">
              {job.current && <span class="badge-now">Atual</span>}
              <p class="exp-period">{job.period}</p>
              <p class="exp-dur">{job.duration}</p>
            </div>
          </div>
          <ul class="exp-hl">
            {job.highlights.slice(0, 2).map((h) => <li set:html={h} />)}
          </ul>
          <div class="exp-tags">
            {job.stack.slice(0, 5).map((t) => <span class="tag">{t}</span>)}
          </div>
        </div>
      ))}
    </div>
  </article>

  <!-- ── Skills ──────────────────────────────── -->
  <article class="cell cell-skills reveal" id="skills">
    <p class="eyebrow">Skills</p>
    <div class="skills-wrap">
      {skillGroups.map((group) => (
        <div class="skill-grp">
          <p class="skill-grp-title">{group.category}</p>
          <ul>
            {group.skills.slice(0, 4).map((s) => <li>{s.name}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </article>

  <!-- ── Education ───────────────────────────── -->
  <article class="cell cell-education reveal" id="educacao">
    <p class="eyebrow">Educação</p>
    <div class="edu-list">
      {education.map((edu, i) => (
        <div class={`edu-item${i < education.length - 1 ? ' sep' : ''}`}>
          <div class="edu-row">
            <div>
              <span class="edu-lvl">{edu.level}</span>
              <p class="edu-fld">{edu.field}</p>
              <p class="edu-inst">{edu.institution}</p>
            </div>
            <p class="edu-per">{edu.period}</p>
          </div>
          <div class="edu-tags">
            {edu.skills.slice(0, 5).map((s) => <span class="tag">{s}</span>)}
          </div>
        </div>
      ))}
    </div>
  </article>

  <!-- ── Contact ─────────────────────────────── -->
  <article class="cell cell-contact reveal" id="contato">
    <p class="eyebrow">Contato</p>
    <div class="contact-list">
      {contactLinks.map((link) => (
        <a href={link.href}
           target={link.href.startsWith('http') ? '_blank' : undefined}
           rel="noopener noreferrer"
           class="contact-item"
           aria-label={`${link.label}: ${link.value}`}>
          <span class="ci-icon" set:html={link.icon} />
          <div class="ci-text">
            <span class="ci-label">{link.label}</span>
            <span class="ci-val">{link.value}</span>
          </div>
          <svg class="ci-arrow" width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
  </article>

</div>

<style>
  /* ── Grid layout ─────────────────────────────────── */
  .bento {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-areas:
      "name    name    photo  "
      "bio     stats   loc    "
      "stack   stack   stack  "
      "exp     exp     skills "
      "edu     edu     contact";
    gap: 0.875rem;
    padding: calc(64px + 2rem) clamp(1.25rem, 5vw, 2.5rem) 2.5rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Base cell ───────────────────────────────────── */
  .cell {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .cell:hover {
    border-color: var(--accent-border);
    box-shadow: 0 2px 20px rgba(79, 70, 229, 0.08);
  }

  /* ── Grid areas ──────────────────────────────────── */
  .cell-name       { grid-area: name;    display: flex; flex-direction: column; justify-content: flex-end; gap: 0.85rem; padding: 2.5rem; background: linear-gradient(145deg, #1e1b4b 0%, #2d2a6e 100%); border-color: transparent; }
  .cell-photo      { grid-area: photo;   display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.65rem; text-align: center; }
  .cell-bio        { grid-area: bio; }
  .cell-stats      { grid-area: stats;   display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--accent-border); padding: 0; overflow: hidden; border-color: var(--accent-border); }
  .cell-location   { grid-area: loc;     display: flex; flex-direction: column; justify-content: center; gap: 1.1rem; }
  .cell-stack      { grid-area: stack; }
  .cell-experience { grid-area: exp; }
  .cell-skills     { grid-area: skills; }
  .cell-education  { grid-area: edu; }
  .cell-contact    { grid-area: contact; padding: 0; overflow: hidden; }

  /* ── Eyebrow label ───────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.67rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--text-muted);
    margin-bottom: 1.1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.25rem;
    height: 1px;
    background: var(--accent);
    opacity: 0.5;
    flex-shrink: 0;
  }

  /* ── Name cell (dark indigo bg) ─────────────────── */
  .cell-name .eyebrow {
    color: rgba(199, 196, 255, 0.6);
  }

  .cell-name .eyebrow::before {
    background: rgba(199, 196, 255, 0.4);
    opacity: 1;
  }

  .big-name {
    font-size: clamp(3rem, 5.5vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.0;
    color: #ffffff;
  }

  .mono-title {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: rgba(199, 196, 255, 0.6);
    letter-spacing: 0.02em;
    min-height: 1.4em;
  }

  .cursor { animation: blink 1.1s step-end infinite; color: #a5b4fc; }

  .name-desc { font-size: 0.83rem; color: rgba(255,255,255,0.55); line-height: 1.5; }
  .name-desc strong { color: rgba(255,255,255,0.9); font-weight: 600; }

  .name-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; padding-top: 0.25rem; }

  /* Buttons inside dark cell */
  .cell-name .btn-primary {
    background: #ffffff;
    color: #1e1b4b;
  }

  .cell-name .btn-primary:hover {
    background: #e0e7ff;
    color: #1e1b4b;
  }

  .cell-name .btn-outline {
    border-color: rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.7);
    background: transparent;
  }

  .cell-name .btn-outline:hover {
    border-color: rgba(255,255,255,0.6);
    color: #ffffff;
    background: rgba(255,255,255,0.08);
  }

  /* ── Photo cell ──────────────────────────────────── */
  .photo-frame {
    width: 80px; height: 80px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-base);
    display: flex; align-items: center; justify-content: center;
  }

  .photo-frame img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .photo-fallback {
    display: none;
    font-family: var(--font-mono);
    font-size: 1rem; font-weight: 500;
    color: var(--text-secondary);
  }

  .photo-frame.no-photo img    { display: none; }
  .photo-frame.no-photo .photo-fallback { display: block; }

  .photo-name { font-size: 0.92rem; font-weight: 600; color: var(--text-primary); }
  .photo-role { font-size: 0.75rem; color: var(--text-secondary); }

  .avail-row {
    display: flex; align-items: center; gap: 0.45rem;
    font-size: 0.72rem; color: var(--text-secondary);
    font-family: var(--font-mono);
  }

  .avail-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #4ade80; flex-shrink: 0;
  }

  /* ── Bio cell ────────────────────────────────────── */
  .bio-text {
    font-size: 0.88rem; color: var(--text-secondary);
    line-height: 1.8; margin-bottom: 1.25rem;
  }

  .bio-text strong { color: var(--text-primary); font-weight: 600; }

  .about-links { display: flex; flex-direction: column; gap: 0.5rem; }

  .about-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem; color: var(--text-muted);
    transition: color var(--transition);
  }

  .about-link:hover { color: var(--accent); }

  /* ── Stats cell (indigo tint) ────────────────────── */
  .stat {
    background: #eef2ff;
    padding: 1.25rem 0.75rem;
    display: flex; flex-direction: column;
    align-items: center; text-align: center; gap: 0.3rem;
  }

  .stat-val {
    font-size: 1.65rem; font-weight: 800;
    font-family: var(--font-mono);
    color: var(--accent); letter-spacing: -0.04em;
  }

  .stat-lbl {
    font-size: 0.65rem; color: #6366f1;
    text-align: center; line-height: 1.3;
    opacity: 0.7;
  }

  /* ── Location cell ───────────────────────────────── */
  .loc-item {
    display: flex; align-items: center; gap: 0.75rem;
    color: var(--text-muted);
  }

  .loc-item svg { flex-shrink: 0; }
  .loc-item div { display: flex; flex-direction: column; gap: 0.1rem; }
  .loc-item strong { font-size: 0.875rem; font-weight: 500; color: var(--text-primary); }
  .loc-item span { font-size: 0.72rem; color: var(--text-muted); }

  /* ── Stack cell ──────────────────────────────────── */
  .badges-wrap { display: flex; flex-wrap: wrap; gap: 0.4rem; }

  /* ── Experience cell ─────────────────────────────── */
  .exp-list { display: flex; flex-direction: column; }

  .exp-item { padding: 1.1rem 0; }
  .exp-item:first-child { padding-top: 0; }
  .exp-item.sep { border-bottom: 1px solid var(--border); }

  .exp-row-top {
    display: flex; justify-content: space-between;
    align-items: flex-start; gap: 1rem; margin-bottom: 0.55rem;
  }

  .exp-co {
    font-family: var(--font-mono); font-size: 0.65rem; font-weight: 400;
    color: var(--text-muted); text-transform: uppercase;
    letter-spacing: 0.1em; margin-bottom: 0.2rem;
  }

  .exp-role-name {
    font-size: 0.92rem; font-weight: 600;
    color: var(--text-primary); letter-spacing: -0.01em;
  }

  .exp-sub { font-weight: 400; color: var(--text-secondary); }

  .exp-right {
    text-align: right; display: flex; flex-direction: column;
    align-items: flex-end; gap: 0.15rem; flex-shrink: 0;
  }

  .badge-now {
    font-family: var(--font-mono); font-size: 0.6rem;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--text-muted); border: 1px solid var(--border-hover);
    border-radius: 100px; padding: 0.1rem 0.45rem;
  }

  .exp-period { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-secondary); }
  .exp-dur    { font-family: var(--font-mono); font-size: 0.62rem; color: var(--text-muted); }

  .exp-hl {
    list-style: none; margin-bottom: 0.55rem;
    display: flex; flex-direction: column; gap: 0.3rem;
  }

  .exp-hl li {
    font-size: 0.8rem; color: var(--text-secondary);
    padding-left: 1rem; position: relative; line-height: 1.6;
  }

  .exp-hl li::before { content: '—'; position: absolute; left: 0; color: var(--border-hover); }
  .exp-hl li :global(strong) { color: var(--text-primary); font-weight: 500; }

  .exp-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }

  /* ── Skills cell ─────────────────────────────────── */
  .skills-wrap { display: flex; flex-direction: column; gap: 1rem; }

  .skill-grp-title {
    font-family: var(--font-mono); font-size: 0.63rem; font-weight: 400;
    text-transform: uppercase; letter-spacing: 0.15em;
    color: var(--text-muted); margin-bottom: 0.45rem;
  }

  .skill-grp ul { list-style: none; display: flex; flex-direction: column; gap: 0.28rem; }
  .skill-grp li { font-size: 0.8rem; color: var(--text-secondary); }

  /* ── Education cell ──────────────────────────────── */
  .edu-list { display: flex; flex-direction: column; }

  .edu-item { padding: 1rem 0; }
  .edu-item:first-child { padding-top: 0; }
  .edu-item.sep { border-bottom: 1px solid var(--border); }

  .edu-row {
    display: flex; justify-content: space-between;
    align-items: flex-start; gap: 1rem; margin-bottom: 0.55rem;
  }

  .edu-lvl {
    font-family: var(--font-mono); font-size: 0.62rem;
    color: var(--text-muted); text-transform: uppercase;
    letter-spacing: 0.12em; margin-bottom: 0.2rem; display: block;
  }

  .edu-fld {
    font-size: 0.98rem; font-weight: 700;
    color: var(--text-primary); letter-spacing: -0.01em; line-height: 1.25;
  }

  .edu-inst { font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.15rem; }

  .edu-per {
    font-family: var(--font-mono); font-size: 0.65rem;
    color: var(--text-muted); text-align: right; flex-shrink: 0; margin-top: 0.25rem;
  }

  .edu-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }

  /* ── Contact cell ────────────────────────────────── */
  .contact-list {
    display: flex; flex-direction: column;
    gap: 1px; background: var(--border);
  }

  .contact-item {
    display: flex; align-items: center; gap: 0.75rem;
    padding: 1rem 1.25rem; background: var(--bg-card);
    text-decoration: none; transition: background var(--transition);
  }

  .contact-item:hover { background: var(--accent-subtle); }
  .contact-item:hover .ci-arrow { transform: translateX(2px); color: var(--accent); }

  .ci-icon {
    display: flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 6px;
    background: var(--bg-base); border: 1px solid var(--border);
    flex-shrink: 0; color: var(--text-secondary);
  }

  .ci-text { display: flex; flex-direction: column; gap: 0.05rem; flex: 1; min-width: 0; }
  .ci-label { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.12em; }
  .ci-val   { font-size: 0.8rem; font-weight: 500; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .ci-arrow { color: var(--text-muted); flex-shrink: 0; transition: color var(--transition), transform var(--transition); }

  /* ── Responsive: tablet ──────────────────────────── */
  @media (max-width: 1024px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-template-areas:
        "name     photo  "
        "bio      stats  "
        "loc      loc    "
        "stack    stack  "
        "exp      exp    "
        "skills   skills "
        "edu      edu    "
        "contact  contact";
    }
  }

  /* ── Responsive: mobile ──────────────────────────── */
  @media (max-width: 600px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas:
        "name   "
        "photo  "
        "bio    "
        "stats  "
        "loc    "
        "stack  "
        "exp    "
        "skills "
        "edu    "
        "contact";
    }
  }
</style>

<script>
  // Typing animation
  const phrases = [
    'Engenheiro de Software .NET',
    'Especialista em Microserviços',
    'Arquiteto de Sistemas Distribuídos',
    'Cloud Engineer · AWS / Azure',
    'Professor de Engenharia de Software',
  ];

  const el = document.getElementById('typing-text');
  if (el) {
    let phraseIdx = 0, charIdx = 0, deleting = false, delay = 110;
    const tick = () => {
      const phrase = phrases[phraseIdx];
      if (deleting) { el.textContent = phrase.slice(0, --charIdx); delay = 50; }
      else           { el.textContent = phrase.slice(0, ++charIdx); delay = 95; }
      if (!deleting && charIdx === phrase.length) { deleting = true; delay = 1800; }
      else if (deleting && charIdx === 0) { deleting = false; phraseIdx = (phraseIdx + 1) % phrases.length; delay = 350; }
      setTimeout(tick, delay);
    };
    setTimeout(tick, 700);
  }

  // Stats: calc years from start year
  const currentYear = new Date().getFullYear();
  document.querySelectorAll<HTMLElement>('.stat-val[data-start-year]').forEach((el) => {
    const y = Number(el.dataset.startYear);
    if (y) el.textContent = `${currentYear - y}+`;
  });
</script>
