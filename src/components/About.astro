---
import { stats, location, aboutLinks } from '../data/about';
---

<section id="sobre" class="section" aria-labelledby="sobre-title">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">sobre mim</p>
      <h2 class="section-title" id="sobre-title">Quem sou eu</h2>
    </div>

    <div class="about-grid">
      <div class="about-bio reveal">
        <p>
          Sou Engenheiro de Software com foco profundo no ecossistema <strong>.NET</strong> e especialização em
          <strong>Arquitetura de Sistemas Distribuídos</strong>. Minha atuação é pautada pela construção de soluções
          escaláveis e resilientes, unindo o domínio técnico do .NET 10 à eficiência de infraestruturas modernas
          baseadas em cloud e containers.
        </p>
        <p>
          Atualmente na <strong>Base2 Tecnologia</strong>, lidero o desenvolvimento de ecossistemas de APIs de alta
          performance com integração nativa à <strong>AWS</strong>, segurança robusta via Cognito, e esteiras de CI/CD
          com qualidade garantida via Sonar e Application Insights.
        </p>
        <p>
          Em paralelo, atuo como <strong>Professor de Ensino Superior</strong> no Centro Universitário Una,
          onde leciono Engenharia de Software, Sistemas Distribuídos e Arquitetura para cursos de Computação —
          buscando reduzir o gap entre teoria acadêmica e a demanda real do mercado.
        </p>

        <div class="about-links">
          {aboutLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class="about-link"
            >
              <Fragment set:html={link.icon} />
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <div class="about-sidebar reveal" style="transition-delay:0.12s">
        <div class="stats-grid">
          {stats.map((stat) => (
            <div class="stat-card">
              <span
                class="stat-value"
                data-start-year={stat.startYear ?? null}
              >
                {stat.value}
              </span>
              <span class="stat-label">{stat.label}</span>
            </div>
          ))}
        </div>

        <div class="meta-list">
          <div class="meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <div>
              <strong>{location.city}</strong>
              <span>{location.region}</span>
            </div>
          </div>
          <div class="meta-item">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <path d="M8 21h8M12 17v4"/>
            </svg>
            <div>
              <strong>{location.workMode}</strong>
              <span>{location.workModeDetail}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
    align-items: start;
  }

  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-bio p {
    color: var(--text-secondary);
    line-height: 1.85;
    font-size: 0.975rem;
  }

  .about-bio strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .about-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-top: 0.75rem;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color var(--transition);
  }

  .about-link:hover { color: var(--text-primary); }

  /* Sidebar */
  .about-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .stat-card {
    background: var(--bg-card);
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.35rem;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 800;
    font-family: var(--font-mono);
    color: var(--text-primary);
    letter-spacing: -0.04em;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: center;
    line-height: 1.4;
  }

  .meta-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-muted);
  }

  .meta-item svg { flex-shrink: 0; }

  .meta-item div {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .meta-item strong {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .meta-item span {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 560px) {
    .stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

<script>
  const currentYear = new Date().getFullYear();

  document.querySelectorAll<HTMLElement>('.stat-value[data-start-year]').forEach((el) => {
    const startYear = Number(el.dataset.startYear);
    if (!startYear) return;
    el.textContent = `${currentYear - startYear}+`;
  });
</script>
