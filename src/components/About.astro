---
const stats = [
  { value: '6+', label: 'Anos de Experiência' },
  { value: '3+', label: 'Anos como Professor' },
  { value: '.NET', label: 'Especialização Core' },
  { value: 'AWS', label: 'Cloud Principal' },
];
---

<section id="sobre" class="section" aria-labelledby="sobre-title">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">sobre mim</p>
      <h2 class="section-title" id="sobre-title">Quem sou eu</h2>
    </div>

    <div class="about-grid">
      <!-- Bio -->
      <div class="about-bio reveal">
        <p>
          Sou Engenheiro de Software com foco profundo no ecossistema <strong>.NET</strong> e especialização em
          <strong>Arquitetura de Sistemas Distribuídos</strong>. Minha atuação é pautada pela construção de soluções
          escaláveis e resilientes, unindo o domínio técnico do .NET 10 à eficiência de infraestruturas modernas
          baseadas em cloud e containers.
        </p>
        <p>
          Atualmente na <strong>Base2 Tecnologia</strong>, lidero o desenvolvimento de ecossistemas de APIs de alta
          performance com integração nativa à <strong>AWS</strong>, segurança robusta via Cognito, e esteiras de CI/CD
          com qualidade garantida via Sonar e Application Insights.
        </p>
        <p>
          Em paralelo, atuo como <strong>Professor de Ensino Superior</strong> no Centro Universitário Una,
          onde leciono Engenharia de Software, Sistemas Distribuídos e Arquitetura para cursos de Computação — sempre
          buscando reduzir o gap entre teoria acadêmica e a demanda real do mercado.
        </p>

        <div class="about-links">
          <a
            href="https://www.linkedin.com/in/danhpaiva/"
            target="_blank"
            rel="noopener noreferrer"
            class="about-link"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            linkedin.com/in/danhpaiva
          </a>
          <a
            href="https://github.com/danhpaiva"
            target="_blank"
            rel="noopener noreferrer"
            class="about-link"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
            github.com/danhpaiva
          </a>
          <a href="mailto:danpaiva@live.com" class="about-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
            danpaiva@live.com
          </a>
          <a href="https://t.me/danhpaiva" target="_blank" rel="noopener noreferrer" class="about-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
            </svg>
            t.me/danhpaiva
          </a>
        </div>
      </div>

      <!-- Stats -->
      <div class="about-stats reveal" style="transition-delay:0.15s">
        {stats.map((stat) => (
          <div class="stat-card">
            <span class="stat-value">{stat.value}</span>
            <span class="stat-label">{stat.label}</span>
          </div>
        ))}

        <!-- Location -->
        <div class="location-card">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue)" stroke-width="2" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <div>
            <strong>Belo Horizonte</strong>
            <span>Minas Gerais, Brasil</span>
          </div>
        </div>

        <!-- Work mode -->
        <div class="location-card">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
          <div>
            <strong>Remoto / Híbrido</strong>
            <span>Aberto a relocação</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 3rem;
    align-items: start;
  }

  .about-bio {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-bio p {
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 1.02rem;
  }

  .about-bio strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .about-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }

  .about-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    transition: color var(--transition);
  }

  .about-link:hover { color: var(--blue); }

  /* Stats */
  .about-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
    transition: border-color var(--transition), transform var(--transition);
  }

  .stat-card:hover {
    border-color: var(--border-glow);
    transform: translateY(-2px);
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 800;
    font-family: var(--font-mono);
    background: var(--gradient-blue);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.78rem;
    color: var(--text-secondary);
    text-align: center;
    line-height: 1.3;
  }

  .location-card {
    grid-column: span 2;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .location-card div {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .location-card strong {
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  .location-card span {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
    }

    .about-stats {
      grid-template-columns: repeat(4, 1fr);
    }

    .location-card { grid-column: span 2; }
  }

  @media (max-width: 560px) {
    .about-stats {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
