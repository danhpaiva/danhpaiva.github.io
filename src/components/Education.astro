---
import { education } from '../data/education';
---

<section id="educacao" class="section" aria-labelledby="edu-title">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">formação acadêmica</p>
      <h2 class="section-title" id="edu-title">Educação</h2>
      <p class="section-subtitle">Base acadêmica sólida, do desenvolvimento ao nível de especialista em arquitetura distribuída.</p>
    </div>

    <div class="edu-grid">
      {education.map((edu, i) => (
        <article
          class="edu-card reveal"
          style={`transition-delay:${i * 0.12}s`}
          aria-label={`${edu.degree} em ${edu.field} — ${edu.institution}`}
        >
          <div class="edu-header">
            <div>
              <span class="edu-level">{edu.level}</span>
              <p class="edu-institution">{edu.institution}</p>
            </div>
          </div>

          <h3 class="edu-field">{edu.field}</h3>
          <p class="edu-degree">{edu.degree}</p>

          <p class="edu-period">{edu.period}</p>

          <p class="edu-desc">{edu.description}</p>

          <div class="edu-skills">
            {edu.skills.map((skill) => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .edu-card {
    background: var(--bg-card);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: background var(--transition);
  }

  .edu-card:hover { background: var(--bg-card-hover); }

  .edu-header {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .edu-institution {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.3;
  }

  .edu-level {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    margin-bottom: 0.3rem;
  }

  .edu-field {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.25;
    letter-spacing: -0.02em;
  }

  .edu-degree {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .edu-period {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    letter-spacing: 0.05em;
  }

  .edu-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .edu-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 480px) {
    .edu-grid { grid-template-columns: 1fr; }
  }
</style>
