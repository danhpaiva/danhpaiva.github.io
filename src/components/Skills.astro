---
import { skillGroups, techBadges } from '../data/skills';
---

<section id="skills" class="section" aria-labelledby="skills-title">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">stack técnica</p>
      <h2 class="section-title" id="skills-title">Skills & Tecnologias</h2>
      <p class="section-subtitle">Especialização profunda no ecossistema .NET com forte domínio em cloud, containers e arquiteturas modernas.</p>
    </div>

    <div class="badges-row reveal" style="margin-bottom:3rem">
      {techBadges.map((badge) => (
        <span class="tag">{badge}</span>
      ))}
    </div>

    <div class="skills-grid">
      {skillGroups.map((group, gi) => (
        <div class="skill-group reveal" style={`transition-delay:${gi * 0.07}s`}>
          <h3 class="skill-category">{group.category}</h3>
          <ul class="skill-list" role="list">
            {group.skills.map((skill) => (
              <li class="skill-item">
                <span class="skill-name">{skill.name}</span>
                <div
                  class="skill-bar-bg"
                  role="progressbar"
                  aria-valuenow={skill.level}
                  aria-valuemin={0}
                  aria-valuemax={100}
                  aria-label={`${skill.name}: ${skill.level}%`}
                >
                  <div
                    class="skill-bar-fill"
                    data-width={skill.level}
                    style="width: 0%"
                  ></div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .badges-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .skill-group {
    background: var(--bg-card);
    padding: 1.5rem;
  }

  .skill-category {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-family: var(--font-mono);
    margin-bottom: 1.1rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--border);
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skill-item {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .skill-name {
    font-size: 0.85rem;
    color: var(--text-secondary);
    font-weight: 400;
  }

  .skill-bar-bg {
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .skill-bar-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--text-muted);
    transition: width 0.9s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  const bars = document.querySelectorAll<HTMLElement>('.skill-bar-fill');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.width = `${el.dataset.width ?? 0}%`;
          observer.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );
  bars.forEach((bar) => observer.observe(bar));
</script>
