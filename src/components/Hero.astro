---
---

<section id="inicio" class="hero" aria-label="Apresentação">
  <div class="container hero-content">

    <div class="hero-photo-wrap animate-fade-up" style="animation-delay:0.1s">
      <div class="hero-photo" id="hero-photo">
        <img
          src="/photo.jpg"
          alt="Daniel Paiva"
          width="88"
          height="88"
          onerror="this.parentElement.classList.add('no-photo')"
        />
        <div class="photo-initials">DP</div>
      </div>
      <div class="status-dot" title="Disponível para oportunidades" aria-label="Disponível para oportunidades"></div>
    </div>

    <h1 class="hero-name animate-fade-up" style="animation-delay:0.2s">
      Daniel Paiva
    </h1>

    <p class="hero-title animate-fade-up" style="animation-delay:0.3s">
      <span class="typing-text" id="typing-text"></span><span class="cursor" aria-hidden="true">_</span>
    </p>

    <p class="hero-desc animate-fade-up" style="animation-delay:0.4s">
      Construo sistemas distribuídos escaláveis e resilientes com <strong>.NET 10</strong>,
      arquiteturas de <strong>microserviços</strong> e infraestrutura moderna em <strong>cloud</strong>.
      Também professor universitário, levando a engenharia de software do mercado para a academia.
    </p>

    <div class="hero-stack animate-fade-up" style="animation-delay:0.5s">
      <span class="tag">.NET 10</span>
      <span class="tag">AWS</span>
      <span class="tag">Docker</span>
      <span class="tag">Kafka</span>
      <span class="tag">Redis</span>
      <span class="tag">SQL Server</span>
    </div>

    <div class="hero-ctas animate-fade-up" style="animation-delay:0.6s">
      <a href="#experiencia" class="btn btn-primary">
        Ver Experiência
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M8 3L13 8L8 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M13 8H3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/danhpaiva/?skipRedirect=true"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/danhpaiva"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-outline"
      >
        GitHub
      </a>
    </div>

    <div class="scroll-hint animate-fade-up" style="animation-delay:1s" aria-hidden="true">
      <div class="scroll-line"></div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 64px;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-top: 3rem;
    padding-bottom: 5rem;
    gap: 1.5rem;
  }

  /* Photo */
  .hero-photo-wrap {
    position: relative;
    display: inline-flex;
  }

  .hero-photo {
    width: 88px;
    height: 88px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--bg-card);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .photo-initials {
    display: none;
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .hero-photo.no-photo img { display: none; }
  .hero-photo.no-photo .photo-initials { display: block; }

  .status-dot {
    position: absolute;
    bottom: 3px;
    right: 3px;
    width: 12px;
    height: 12px;
    background: #4ade80;
    border-radius: 50%;
    border: 2px solid var(--bg-base);
  }

  /* Name */
  .hero-name {
    font-size: clamp(2.75rem, 8vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--text-primary);
    line-height: 1.05;
  }

  /* Typing title */
  .hero-title {
    font-family: var(--font-mono);
    font-size: clamp(0.9rem, 2.2vw, 1.15rem);
    font-weight: 400;
    color: var(--text-muted);
    min-height: 1.6em;
    letter-spacing: 0.01em;
  }

  .cursor {
    color: var(--text-muted);
    animation: blink 1.1s step-end infinite;
  }

  /* Description */
  .hero-desc {
    max-width: 560px;
    color: var(--text-secondary);
    font-size: clamp(0.9rem, 2vw, 1rem);
    line-height: 1.8;
    font-weight: 400;
  }

  .hero-desc strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  /* Stack */
  .hero-stack {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  /* Scroll hint */
  .scroll-hint {
    margin-top: 1.5rem;
    display: flex;
    justify-content: center;
  }

  .scroll-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, transparent, var(--border-hover));
  }

  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column; align-items: stretch; }
    .hero-ctas .btn { justify-content: center; }
  }
</style>

<script>
  const phrases = [
    'Engenheiro de Software .NET',
    'Especialista em Microserviços',
    'Arquiteto de Sistemas Distribuídos',
    'Cloud Engineer · AWS / Azure',
    'Professor de Engenharia de Software',
  ];

  const el = document.getElementById('typing-text');
  if (el) {
    let phraseIdx = 0;
    let charIdx = 0;
    let deleting = false;
    let delay = 110;

    const tick = () => {
      const phrase = phrases[phraseIdx];
      if (deleting) {
        el.textContent = phrase.slice(0, --charIdx);
        delay = 55;
      } else {
        el.textContent = phrase.slice(0, ++charIdx);
        delay = 95;
      }

      if (!deleting && charIdx === phrase.length) {
        deleting = true;
        delay = 1800;
      } else if (deleting && charIdx === 0) {
        deleting = false;
        phraseIdx = (phraseIdx + 1) % phrases.length;
        delay = 350;
      }

      setTimeout(tick, delay);
    };

    setTimeout(tick, 800);
  }
</script>
