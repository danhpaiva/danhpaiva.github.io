---
import { contactLinks as links } from '../data/contact';
---

<section id="contato" class="section" aria-labelledby="contact-title">
  <div class="container">
    <div class="contact-wrap reveal">
      <div class="section-header" style="margin-bottom:2.5rem">
        <p class="section-label">vamos conversar</p>
        <h2 class="section-title" id="contact-title">Entre em Contato</h2>
        <p class="section-subtitle">
          Aberto a novas oportunidades, projetos desafiadores e conversas sobre engenharia de software.
        </p>
      </div>

      <div class="contact-links">
        {links.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="contact-link"
            aria-label={`${link.label}: ${link.value}`}
          >
            <span class="link-icon" set:html={link.icon} />
            <div class="link-text">
              <span class="link-label">{link.label}</span>
              <span class="link-value">{link.value}</span>
            </div>
            <svg class="link-arrow" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-wrap {
    max-width: 640px;
    margin: 0 auto;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    background: var(--bg-card);
    text-decoration: none;
    transition: background var(--transition);
  }

  .contact-link:hover {
    background: var(--bg-card-hover);
  }

  .contact-link:hover .link-arrow {
    transform: translateX(3px);
    color: var(--text-secondary);
  }

  .link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 6px;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    flex-shrink: 0;
    color: var(--text-secondary);
  }

  .link-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    flex: 1;
    min-width: 0;
  }

  .link-label {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-family: var(--font-mono);
  }

  .link-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color var(--transition), transform var(--transition);
  }
</style>
