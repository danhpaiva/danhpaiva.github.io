---
const links = [
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/danhpaiva',
    href: 'https://www.linkedin.com/in/danhpaiva/',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
    color: 'blue',
    primary: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/danhpaiva',
    href: 'https://github.com/danhpaiva',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
    color: 'cyan',
    primary: false,
  },
  {
    label: 'E-mail',
    value: 'daniel.paiva@baselabs.com.br',
    href: 'mailto:daniel.paiva@baselabs.com.br',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/></svg>`,
    color: 'green',
    primary: false,
  },
];
---

<section id="contato" class="section" aria-labelledby="contact-title">
  <div class="container">
    <div class="contact-wrap reveal">
      <!-- Glow bg -->
      <div class="contact-glow" aria-hidden="true"></div>

      <div class="contact-inner">
        <div class="section-header" style="margin-bottom:2rem">
          <p class="section-label">vamos conversar</p>
          <h2 class="section-title" id="contact-title">Entre em Contato</h2>
          <p class="section-subtitle">
            Aberto a novas oportunidades, projetos desafiadores e conversas sobre engenharia de software.
            Me encontre nas redes abaixo.
          </p>
        </div>

        <div class="contact-links">
          {links.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              class={`contact-link ${link.primary ? 'primary' : ''}`}
              aria-label={`${link.label}: ${link.value}`}
            >
              <span class={`link-icon icon-${link.color}`} set:html={link.icon} />
              <div class="link-text">
                <span class="link-label">{link.label}</span>
                <span class="link-value">{link.value}</span>
              </div>
              <svg class="link-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-wrap {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    max-width: 720px;
    margin: 0 auto;
  }

  .contact-glow {
    position: absolute;
    top: -60px; left: 50%;
    transform: translateX(-50%);
    width: 400px; height: 200px;
    background: radial-gradient(ellipse, rgba(88,166,255,0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-inner {
    position: relative;
    z-index: 1;
    padding: clamp(2rem, 5vw, 3.5rem);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 1.1rem 1.25rem;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    transition: border-color var(--transition), transform var(--transition), box-shadow var(--transition), background var(--transition);
  }

  .contact-link:hover {
    border-color: var(--border-glow);
    transform: translateX(4px);
    background: var(--bg-card-hover);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .contact-link.primary {
    border-color: rgba(88,166,255,0.3);
    background: rgba(88,166,255,0.04);
  }

  .contact-link.primary:hover {
    background: rgba(88,166,255,0.08);
    border-color: rgba(88,166,255,0.5);
  }

  .link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px; height: 44px;
    border-radius: 10px;
    flex-shrink: 0;
  }

  .icon-blue  { background: rgba(88,166,255,0.12); color: var(--blue); }
  .icon-cyan  { background: rgba(57,208,216,0.12); color: var(--cyan); }
  .icon-green { background: rgba(63,185,80,0.12);  color: var(--green); }

  .link-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1;
    min-width: 0;
  }

  .link-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .link-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .link-arrow {
    color: var(--text-muted);
    flex-shrink: 0;
    transition: color var(--transition), transform var(--transition);
  }

  .contact-link:hover .link-arrow {
    color: var(--blue);
    transform: translateX(3px);
  }
</style>
