---
import { jobs } from '../data/experience';
---

<section id="experiencia" class="section" aria-labelledby="exp-title">
  <div class="container">
    <div class="section-header reveal">
      <p class="section-label">trajetória profissional</p>
      <h2 class="section-title" id="exp-title">Experiência</h2>
      <p class="section-subtitle">Construindo soluções de alto impacto em tecnologia e educação.</p>
    </div>

    <div class="timeline">
      {jobs.map((job, i) => (
        <article
          class="timeline-item reveal"
          style={`transition-delay:${i * 0.1}s`}
          aria-label={`${job.role} na ${job.company}`}
        >
          <div class="timeline-dot" aria-hidden="true">
            {job.current && <div class="dot-active"></div>}
          </div>

          <div class="timeline-card">
            <div class="exp-header">
              <div class="exp-top-row">
                <span class="exp-company">{job.company}</span>
                {job.current && <span class="current-badge">Atual</span>}
              </div>
              <h3 class="exp-role">
                {job.role}
                {job.subtitle && <span class="exp-subtitle"> · {job.subtitle}</span>}
              </h3>
              <div class="exp-meta">
                <span>{job.period}</span>
                <span class="sep">·</span>
                <span class="exp-duration">{job.duration}</span>
                <span class="sep">·</span>
                <span>{job.location}</span>
              </div>
            </div>

            <ul class="exp-highlights">
              {job.highlights.map((h) => (
                <li set:html={h} />
              ))}
            </ul>

            <div class="exp-stack">
              {job.stack.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.4rem;
    top: 10px;
    bottom: 10px;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2.5rem;
  }

  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-dot {
    position: absolute;
    left: -1.65rem;
    top: 0.9rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--border-hover);
    border: 1.5px solid var(--bg-base);
    z-index: 1;
  }

  .dot-active {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    border: 1.5px solid var(--border-hover);
    opacity: 0.5;
  }

  /* Card */
  .timeline-card {
    padding: 1.5rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    transition: border-color var(--transition);
  }

  .timeline-card:hover { border-color: var(--border-hover); }

  .exp-header { margin-bottom: 1.1rem; }

  .exp-top-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.4rem;
  }

  .exp-company {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .current-badge {
    padding: 0.1rem 0.5rem;
    background: transparent;
    border: 1px solid var(--border-hover);
    border-radius: 100px;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .exp-role {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.35;
    letter-spacing: -0.01em;
  }

  .exp-subtitle {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--text-secondary);
  }

  .exp-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    flex-wrap: wrap;
  }

  .sep { color: var(--border-hover); }
  .exp-duration { color: var(--text-muted); }

  /* Highlights */
  .exp-highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-bottom: 1.1rem;
  }

  .exp-highlights li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .exp-highlights li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--border-hover);
    font-size: 0.75rem;
    top: 0.1em;
  }

  .exp-highlights li :global(strong) {
    color: var(--text-primary);
    font-weight: 500;
  }

  .exp-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  @media (max-width: 600px) {
    .timeline { padding-left: 1.5rem; }
    .timeline-dot { left: -1.2rem; }
  }
</style>
